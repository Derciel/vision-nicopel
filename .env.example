# Copie este arquivo para .env.local e preencha com seus valores reais
# NÃO commite o .env.local no git

# ID da pasta no Google Drive onde as mídias serão armazenadas
GOOGLE_DRIVE_FOLDER_ID=seu_folder_id_aqui

# Credenciais da Service Account do Google (JSON completo em uma linha)
# Para gerar: acesse o Google Cloud Console > IAM > Service Accounts > Chaves
# Cole o conteúdo inteiro do JSON aqui como string
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
